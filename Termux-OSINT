import requests
import sys
import time
from colorama import Fore, init
from bs4 import BeautifulSoup

init(autoreset=True)

class GitHubOSINT:
    def __init__(self, token=None):
        self.headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "Accept": "application/vnd.github.v3+json"
        }
        if token:
            self.headers["Authorization"] = f"token {token}"

    def user_info(self, username):
        """Информация о пользователе GitHub"""
        r = requests.get(f"https://api.github.com/users/{username}", headers=self.headers)
        if r.status_code == 200:
            data = r.json()
            print(Fore.GREEN + f"\n👤 Пользователь: {data['login']}")
            if data.get('name'):
                print(Fore.CYAN + f"   Имя: {data['name']}")
            print(Fore.CYAN + f"   Локация: {data.get('location', 'Не указано')}")
            print(Fore.CYAN + f"   Репозитории: {data['public_repos']}")
            print(Fore.CYAN + f"   Подписчики: {data['followers']} | Подписки: {data['following']}")
            print(Fore.CYAN + f"   Сайт: {data.get('blog', 'Нет')}")
        elif r.status_code == 404:
            print(Fore.RED + "❌ Пользователь не найден")
        elif r.status_code == 403:
            print(Fore.RED + "❌ Лимит запросов GitHub. Используй Personal Access Token")
        else:
            print(Fore.RED + f"❌ Ошибка: {r.status_code}")

    def search_repos(self, query):
        """Поиск репозиториев"""
        url = f"https://api.github.com/search/repositories?q={query}&per_page=10&sort=stars"
        r = requests.get(url, headers=self.headers)
        if r.status_code == 200:
            items = r.json().get('items', [])
            print(Fore.GREEN + f"\n🔍 Найдено результатов: {len(items)}")
            for repo in items:
                print(Fore.YELLOW + f"\n📦 {repo['full_name']}")
                print(Fore.CYAN + f"   ⭐ {repo['stargazers_count']}  🍴 {repo['forks_count']}")
                print(Fore.CYAN + f"   {repo['html_url']}")
                if repo.get('description'):
                    print(Fore.CYAN + f"   {repo['description'][:100]}...")
        else:
            print(Fore.RED + "❌ Ошибка поиска")

def main():
    print(Fore.CYAN + "╔════════════════════════════════════════════╗")
    print(Fore.CYAN + "║          🕵️  OSINT TOOL v1.0               ║")
    print(Fore.CYAN + "║             GitHub Module                  ║")
    print(Fore.CYAN + "╚════════════════════════════════════════════╝\n")

    gh = GitHubOSINT()  # Можно добавить token= "ghp_..."

    while True:
        print(Fore.YELLOW + "\n[1] Информация о GitHub пользователе")
        print(Fore.YELLOW + "[2] Поиск репозиториев по ключевому слову")
        print(Fore.YELLOW + "[3] Выход")
        
        choice = input(Fore.CYAN + "\nВыберите действие (1-3): ").strip()
        
        if choice == "1":
            user = input(Fore.CYAN + "Введите GitHub username: ").strip()
            if user:
                gh.user_info(user)
        elif choice == "2":
            query = input(Fore.CYAN + "Введите поисковый запрос (например: osint python): ").strip()
            if query:
                gh.search_repos(query)
        elif choice == "3":
            print(Fore.GREEN + "👋 До свидания!")
            break
        else:
            print(Fore.RED + "❌ Неверный выбор! Введите 1, 2 или 3.")

        input(Fore.CYAN + "\nНажмите Enter для продолжения...")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(Fore.GREEN + "\n\nПрограмма завершена.")
    except Exception as e:
        print(Fore.RED + f"\nОшибка: {e}")
